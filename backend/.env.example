# Server
PORT=3001

# SQLite path
DB_PATH=./data/couture.db

# Google Sheets — Glossary (партнёры + ссылки)
GLOSSARY_SHEET_ID=your_google_sheet_id
GLOSSARY_TAB=Лист1
GOOGLE_CREDENTIALS_PATH=./credentials/google-service.json

# OnlyFansAPI — заполнится позже
ONLYFANSAPI_KEY=
ONLYFANSAPI_ACCOUNT_FREE=
ONLYFANSAPI_ACCOUNT_VIP=

# OnlyMonster CRM API — реальные subscribed_at, transactions, chargebacks
# platform_account_id = OnlyFans numeric id (совпадает с onlyfans_id из OnlyFansAPI)
ONLYMONSTER_TOKEN=
ONLYMONSTER_ACCOUNT_FREE=
ONLYMONSTER_ACCOUNT_VIP=

# Dashboard auth — простой пароль для команды
DASHBOARD_PASSWORD=changeme
